# Copy to /etc/fraud-generator-helper/fraud-generator-helper.env (chmod 600, owned by the fraudgen user)
# and reference these names from config.conf via env:VAR_NAME, e.g.:
#   [aws]
#   secret_access_key = env:AWS_SECRET_ACCESS_KEY
#
# This file is loaded by systemd's EnvironmentFile= directive, never committed to git.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MQTT_PASSWORD=
